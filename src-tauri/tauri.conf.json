{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Refinish",
  "version": "0.1.0",
  "identifier": "sh.refini.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Refinish",
        "width": 900,
        "height": 600,
        "minWidth": 600,
        "minHeight": 400,
        "transparent": true,
        "windowEffects": {
          "effects": ["underWindowBackground", "micaDark", "acrylic"],
          "state": "active"
        }
      },
      {
        "label": "settings",
        "title": "Settings",
        "url": "index.html#settings",
        "width": 480,
        "height": 380,
        "resizable": false,
        "visible": false,
        "transparent": true,
        "decorations": true,
        "windowEffects": {
          "effects": ["underWindowBackground", "micaDark", "acrylic"],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
